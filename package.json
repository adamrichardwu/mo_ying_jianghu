{
  "name": "mo-ying-jianghu",
  "version": "1.1.0",
  "description": "A martial arts adventure game set in a fictional world.",
  "main": "src/main.ts",
  "scripts": {
    "start": "vite",
    "cli": "ts-node -P tsconfig.node.json src/main.ts",
    "build": "npm run build:web && npm run build:cli",
    "build:web": "vite build",
    "build:cli": "tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:portraits": "vitest run tests/portrait-quality.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mo-ying-jianghu.git"
  },
  "keywords": [
    "game",
    "martial arts",
    "adventure"
  ],
  "author": "Your Name",
  "license": "MIT"
}